{
  "name": "@risklab/styler",
  "version": "0.1.0",
  "description": "Typed atomic styling engine for production application interfaces.",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./server": {
      "types": "./dist/types/server.d.ts",
      "import": "./dist/esm/server.js",
      "require": "./dist/cjs/server.js"
    },
    "./compiler": {
      "types": "./dist/types/compiler.d.ts",
      "import": "./dist/esm/compiler.js",
      "require": "./dist/cjs/compiler.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json && tsc -p tsconfig.cjs.json && node scripts/write-cjs-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": ["css", "atomic-css", "typescript", "design-system", "theming", "ssr", "risklab"],
  "author": "RiskLab Contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rpwalsh/risklab-styler"
  },
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20.0.0" },
  "devDependencies": {
    "jsdom": "^29.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
