{
  "name": "@risklab/styler",
  "version": "1.0.0",
  "description": "Typed atomic styling engine for production application interfaces.",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./server": {
      "types": "./dist/types/server.d.ts",
      "import": "./dist/esm/server.js",
      "require": "./dist/cjs/server.js"
    },
    "./compiler": {
      "types": "./dist/types/compiler.d.ts",
      "import": "./dist/esm/compiler.js",
      "require": "./dist/cjs/compiler.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json && tsc -p tsconfig.cjs.json && node scripts/write-cjs-package.mjs",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/check-source.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test",
    "check": "npm run lint && npm run typecheck && npm run test",
    "prepack": "npm run check && npm run build",
    "pack:check": "node scripts/test-consumer.mjs",
    "release:check": "npm run check && npm run test:coverage && npm run build && npm run test:browser && npm run pack:check",
    "validate": "npm run release:check"
  },
  "keywords": [
    "css",
    "atomic-css",
    "typescript",
    "design-system",
    "theming",
    "ssr",
    "risklab"
  ],
  "author": "Sarah Walsh",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/devgrrl/risklab-styler"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitest/coverage-v8": "^3.2.7",
    "jsdom": "^29.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.7"
  }
}
